{
  "id": "promo",
  "name": "Promotional Email",
  "version": "1.0.0",
  "cfModel": "EmailCampaign",
  "fields": {
    "heroHeadline": {
      "type": "text",
      "required": true,
      "binding": "cf.heroHeadline",
      "modelId": "hero"
    },
    "subtitle": {
      "type": "text",
      "required": false,
      "binding": "cf.subtitle",
      "modelId": "hero"
    },
    "bodyCopy": {
      "type": "richtext",
      "required": true,
      "binding": "cf.bodyCopy",
      "modelId": "body-text"
    },
    "ctaText": {
      "type": "text",
      "required": true,
      "binding": "cf.ctaText",
      "modelId": "cta"
    },
    "ctaUrl": {
      "type": "url",
      "required": true,
      "binding": "cf.ctaUrl",
      "modelId": "cta"
    },
    "featuredOffer": {
      "type": "reference",
      "model": "Offer",
      "required": false,
      "binding": "cf.featuredOffer"
    }
  },
  "profileTokens": ["profile.person.name.firstName"],
  "previewSize": { "width": 600, "height": 800 }
}
