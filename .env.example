# Fragment Mailer — environment variables
# Copy to .dev.vars for local Wrangler dev (wrangler reads .dev.vars, not .env)

# Set to "true" to use mock fixtures instead of real AEM/AJO APIs.
# All contributors without AEM/AJO access should use MOCK_MODE=true.
MOCK_MODE=true

# AEM tier: publish (Content Fragment Delivery / GraphQL) or author (Sites CF Management API)
# AEM_TIER=publish
# AEM_TIER=author

# AEM host — must match tier (publish-* or author-* hostname)
AEM_BASE_URL=https://publish-p12345-e67890.adobeaemcloud.com
# Author example:
# AEM_BASE_URL=https://author-p125048-e1847106.adobeaemcloud.com

# Omit for open publish, or set the real CDN Edge Key. Placeholder values are not sent as X-Api-Key.
# AEM_API_KEY=
# Folder containing email campaign content fragments
AEM_CAMPAIGNS_PATH=/content/dam/email/en/campaigns

# Publish only — fetch mode: openapi (Content Fragment Delivery) or graphql (persisted queries)
# Use graphql while /adobe/contentFragments is not enabled on publish
AEM_FETCH_MODE=openapi
# GraphQL persisted-query settings (when AEM_FETCH_MODE=graphql)
# AEM_GRAPHQL_ENDPOINT=email
# AEM_GRAPHQL_LIST_QUERY=campaigns-all
# AEM_GRAPHQL_BY_PATH_QUERY=campaign-by-path
# AEM_GRAPHQL_BY_PATH_PARAM=campaignPath

# Author tier — OAuth server-to-server (AEM CS Sites Content Management API product)
# Option A: set in .dev.vars / Wrangler secrets
IMS_CLIENT_ID=your-client-id
IMS_CLIENT_SECRET=your-client-secret
IMS_ORG_ID=ABCDEF123456789A@AdobeOrg
# IMS_HOST=ims-na1.adobelogin.com
# IMS_SCOPES=openid,AdobeID,aem.folders,aem.assets.author,aem.fragments.management

# Option B: copy oauth.example.json → oauth.json (gitignored, local Node dev only)
# OAUTH_CONFIG_PATH=oauth.json

# AJO
AJO_SANDBOX=prod
# AJO_SANDBOX_NAME=prod
# AJO_IMS_CLIENT_ID=
# AJO_IMS_CLIENT_SECRET=
# Publish host for AJO fragment repoId (hostname used in fragment(id='aem:UUID?repoId=...'))
# AEM_PUBLISH_HOST=https://publish-p12345-e67890.adobeaemcloud.com
# Optional explicit Author host when AEM_TIER=publish but export uses Author API
# AEM_AUTHOR_HOST=https://author-p125048-e1847106.adobeaemcloud.com
